# Copy this to .env and fill in your values
# Never commit .env — only .env.example

DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here

# PostgreSQL (local dev)
POSTGRES_DB=pokemon_battle
POSTGRES_USER=pokemon_user
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis — required for Loteria WebSocket channel layer
# REDIS_URL=redis://localhost:6379/0

# ── Railway deployment ────────────────────────────────────────────────────────
# Set these in the Railway dashboard under Variables (not in .env).
# Railway injects DATABASE_URL and REDIS_URL automatically from its plugins.
#
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<openssl rand -hex 50>
# DATABASE_URL=<auto-injected by Railway PostgreSQL plugin>
# REDIS_URL=<auto-injected by Railway Redis plugin>
# ALLOWED_HOSTS=pokemon-amigo.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://pokemon-amigo.up.railway.app
